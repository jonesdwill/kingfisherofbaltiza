---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="header-top">
		<div class="header-top-inner">
			<div class="site-title">
				<a href="/">{SITE_TITLE}</a>
			</div>
		</div>
	</div>
	<nav class="main-nav">
		<div class="nav-inner">
			<HeaderLink href="/">Home</HeaderLink>
			<span class="sep">|</span>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<span class="sep">|</span>
			<div class="dropdown">
				<span class="dropdown-label">Expeditions ▾</span>
				<div class="dropdown-menu">
					<a href="/greenland-2026">Greenland 2026</a>
				</div>
			</div>
			<span class="sep">|</span>
			<HeaderLink href="/gallery">Gallery</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		background: #a03010;
		border-bottom: 2px solid #7a2308;
	}

	.header-top {
		padding: 0.8rem 1rem 0.7rem;
	}

	.header-top-inner {
		max-width: 960px;
		margin: 0 auto;
	}

	.site-title a {
		color: #ffffff;
		text-decoration: none;
		font-family: Georgia, 'Times New Roman', Times, serif;
		font-weight: bold;
		font-size: 1.25rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.site-title a:hover {
		color: #fff;
		text-decoration: none;
	}

	.main-nav {
		background: #7a2308;
		border-top: 1px solid #5a1a04;
	}

	.nav-inner {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1rem;
		display: flex;
		align-items: center;
		flex-wrap: wrap;
	}

	.nav-inner :global(a) {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		font-family: Georgia, 'Times New Roman', Times, serif;
		font-size: 0.68rem;
		font-weight: bold;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.5rem 0.7rem;
		display: inline-block;
	}

	.nav-inner :global(a:hover) {
		color: #ffffff;
		background: rgba(0, 0, 0, 0.15);
		text-decoration: none;
	}

	.nav-inner :global(a.active) {
		color: #fff;
		background: rgba(0, 0, 0, 0.2);
	}

	.sep {
		color: rgba(255, 255, 255, 0.3);
		font-size: 0.8rem;
		user-select: none;
	}

	/* Expeditions dropdown */
	.dropdown {
		position: relative;
		display: inline-block;
	}

	.dropdown-label {
		color: rgba(255, 255, 255, 0.85);
		font-family: Georgia, 'Times New Roman', Times, serif;
		font-size: 0.68rem;
		font-weight: bold;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.5rem 0.7rem;
		display: inline-block;
		cursor: default;
		user-select: none;
	}

	.dropdown:hover .dropdown-label {
		color: #ffffff;
		background: rgba(0, 0, 0, 0.15);
	}

	.dropdown-menu {
		display: none;
		position: absolute;
		top: 100%;
		left: 0;
		background: #5a1a04;
		border: 1px solid #3a0e02;
		min-width: 160px;
		z-index: 200;
	}

	.dropdown:hover .dropdown-menu {
		display: block;
	}

	.dropdown-menu a {
		display: block;
		padding: 0.45rem 0.8rem;
		color: rgba(255, 255, 255, 0.9) !important;
		text-decoration: none !important;
		font-family: Georgia, 'Times New Roman', Times, serif;
		font-size: 0.68rem;
		font-weight: bold;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}

	.dropdown-menu a:hover {
		background: rgba(0, 0, 0, 0.2);
		color: #ffffff !important;
	}
</style>
