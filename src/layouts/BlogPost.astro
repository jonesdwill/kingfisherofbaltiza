---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	prevPost?: { id: string; title: string } | null;
	nextPost?: { id: string; title: string } | null;
};

const { title, description, pubDate, updatedDate, heroImage, prevPost, nextPost } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.prose {
				max-width: 720px;
				margin: 0 auto;
				padding: 1.5rem 1rem;
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--text-dim);
				font-size: 0.85em;
			}
			.last-updated-on {
				font-style: italic;
			}
			.comments-box {
				margin: 1rem 0;
				padding-top: 0.5rem;
				border-top: 1px solid var(--border);
				font-family: Georgia, serif;
			}
			#cusdis_thread {
				margin-top: 0.5rem;
				font-family: Georgia, serif;
			}
			.post-nav {
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 0.5rem;
				margin: 1.5rem 0 0.5rem;
				padding: 0.75rem 0;
				border-top: 1px solid var(--border);
				border-bottom: 1px solid var(--border);
				font-size: 0.82em;
			}
			.post-nav a {
				color: var(--link);
				text-decoration: none;
			}
			.post-nav a:hover { text-decoration: underline; }
			.post-nav-prev { text-align: left; max-width: 38%; }
			.post-nav-index {
				text-transform: uppercase;
				letter-spacing: 0.06em;
				white-space: nowrap;
				color: var(--text-dim);
				font-size: 0.9em;
			}
			.post-nav-next { text-align: right; max-width: 38%; }
		</style>
	</head>

	<body>
		<Header />
		<div class="page-column">
		<article>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />

				<nav class="post-nav">
					{prevPost
						? <a class="post-nav-prev" href={`/blog/${prevPost.id}/`}>← {prevPost.title}</a>
						: <span class="post-nav-prev" />}
					<a class="post-nav-index" href="/blog">All Posts</a>
					{nextPost
						? <a class="post-nav-next" href={`/blog/${nextPost.id}/`}>{nextPost.title} →</a>
						: <span class="post-nav-next" />}
				</nav>

				<div class="subscribe-box">
					<p class="section-head">Get updates by email</p>
					<form action="https://app.kit.com/forms/9598410/subscriptions?success_url=https://www.kingfisherofbaltiza.co.uk/subscribe-success" method="post">
						<input type="email" name="email_address" required placeholder="Enter your email" />
						<button type="submit">Subscribe</button>
					</form>
				</div>

				<hr />

				<div class="comments-box">
					<p class="section-head">Comments</p>
					<div id="cusdis_thread"
						data-host="https://cusdis.com"
						data-app-id="3b82d991-2b67-4524-8cab-a961c6896d7c"
						data-page-id={Astro.url.pathname}
						data-page-url={Astro.url.href}
						data-page-title={title}
					></div>
				</div>
				<script>
					window.CUSDIS_LOCALE = { nickname: 'Name', fontFamily: 'Georgia, serif' };
				</script>
				<script async defer src="https://cusdis.com/js/cusdis.es.js"></script>

			</div>
		</article>
		</div><!-- /.page-column -->
		<Footer />
	</body>
</html>
