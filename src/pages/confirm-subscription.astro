---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Confirmed — ${SITE_TITLE}`} description="Subscription confirmed" />
	</head>
	<body>
		<Header />
		<div class="page-column">
			<div class="message-box">
				<p class="section-head">All done</p>
				<h2>You're confirmed!</h2>
				<p>Thank you for subscribing to updates from Kingfisher of Baltiza. You'll hear from us whenever there's news from the boat or the expedition.</p>
				<a class="more-link" href="/">Back to home &rarr;</a>
			</div>
		</div>
		<Footer />
	</body>
</html>

<style>
	.message-box {
		max-width: 560px;
		margin: 2rem auto;
		padding: 2rem;
		background: var(--off-white);
		border-top: 3px solid var(--red);
	}
	.message-box h2 {
		margin: 0.25rem 0 0.75rem;
		font-size: 1.5em;
	}
	.message-box p {
		line-height: 1.6;
		margin: 0 0 1rem;
		color: var(--text);
	}
</style>
