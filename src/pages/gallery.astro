---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Gallery — ${SITE_TITLE}`} description="Photos from Kingfisher of Baltiza — boatyard preparations, crew, and expedition imagery." />
	</head>
	<body>
		<Header />
		<div class="page-column">
			<div class="gallery-wrap">
				<h2 class="section-head">Gallery</h2>

				<div class="photo-grid">
					{images.map((img) => (
						<a href={`/gallery/${img}`} target="_blank" class="photo-thumb">
							<img src={`/gallery/${img}`} alt="" loading="lazy" />
						</a>
					))}
				</div>
			</div>
		</div>
		<Footer />
	</body>
</html>

<style>
	.gallery-wrap {
		padding: 1rem;
	}

	.photo-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 6px;
		margin-top: 1rem;
	}

	.photo-thumb {
		display: block;
		overflow: hidden;
		border: 1px solid var(--border);
	}

	.photo-thumb img {
		display: block;
		width: 100%;
		height: 160px;
		object-fit: cover;
		transition: opacity 0.15s;
	}

	.photo-thumb:hover img {
		opacity: 0.85;
	}

	@media (max-width: 700px) {
		.photo-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
