---
import { getCollection, getEntry, render } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Layout from '../layouts/BlogPost.astro';

const entry = await getEntry('pages', 'greenland-2026');
if (!entry) throw new Error('greenland-2026 page not found');
const { Content } = await render(entry);

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title={entry.data.title} description={entry.data.description} pubDate={entry.data.pubDate ?? new Date()}>
  <Content />
  <div class="expedition-updates">
    <p class="section-head">Blog Updates</p>
    {posts.map((post) => (
      <div class="update-entry">
        <a href={`/blog/${post.id}/`}>{post.data.title}</a>
        <span class="update-date"><FormattedDate date={post.data.pubDate} /></span>
      </div>
    ))}
    <a class="more-link" style="display:block; margin-top:0.75rem;" href="/blog">All posts &rarr;</a>
  </div>
</Layout>

<style>
  .expedition-updates {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .update-entry {
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
  }
  .update-entry a {
    font-weight: bold;
    font-size: 0.9em;
    text-decoration: none;
    color: var(--link);
  }
  .update-entry a:hover { text-decoration: underline; }
  .update-date {
    display: block;
    font-size: 0.75em;
    color: var(--text-dim);
  }
</style>
