---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="preload" as="image" href="/cover.jpg" fetchpriority="high" />
	</head>
	<body>
		<Header />

		<div class="page-column">
			<div class="site-banner-wrap">
				<img class="site-banner" src="/cover.jpg" alt="Kingfisher of Baltiza" fetchpriority="high" loading="eager" />
			</div>

			<div class="home-layout">
				<main class="home-main">
					<p class="section-head">About Kingfisher</p>
					<p>
					Welcome to the webpage of Kingfisher of Baltiza, and her skipper Meg Loftus.
					</p>

					<p>
					Kingfisher is a 32ft William Atkin 'Eric' class yacht built in Malaysia in 1974 using the powerful tropical hardwood Chengai. 
					She is a Bermudan ketch rig on a keel stepped main mast and deck stepped mizzen mast. She is beautifully built and incredibly seaworthy.
					</p>

					<p>
					She had a thorough refit in 2015, and shortly after Meg acquired her and continued to work on her at the Johnson and Loftus boatyard in Ullapool. 
					Meg has taken her all around the Hebrides, Ireland and more recently to Norway in the summer of 2025.  
					</p>

					<p>
					Her sister ship is the well-known Suhali, used by Sir Robin Knox-Johnston to complete the first-ever solo, non-stop circumnavigation of the globe in the 1968-1969 Sunday Times Golden Globe Race.
					</p>

					<hr />

					<div class="home-boxes">
						<div class="content-box">
							<h3>Greenland 2026</h3>
							<p>Preparation is in full swing for the KF's July expedition to Graah's Havn. Learn more about our attempt to climb here.</p>
							<a class="more-link" href="/greenland-2026">View expedition details &rarr;</a>
						</div>

						<div class="content-box">
							<h3>Blog</h3>
							<p>Follow for updates on the general whereabouts of Kingfisher.</p>
							<a class="more-link" href="/blog">Browse all posts &rarr;</a>
						</div>

						<div class="content-box">
							<h3>Gallery</h3>
							<p>Photos from time aboard Kingfisher.</p>
							<a class="more-link" href="/gallery">Browse photos &rarr;</a>
						</div>

					</div>
				</main>

				<aside class="home-sidebar">
					<p class="section-head">Recent Updates</p>
					{recentPosts.map((post) => (
						<div class="recent-post">
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
							<span class="recent-date"><FormattedDate date={post.data.pubDate} /></span>
						</div>
					))}
					<a class="more-link" style="display:block; margin-top: 0.75rem;" href="/blog">All posts &rarr;</a>
				</aside>
			</div>
		</div><!-- /.page-column -->

		<Footer />
	</body>
</html>

<style>
	.home-layout {
		display: grid;
		grid-template-columns: 1fr 220px;
		gap: 1.5rem;
		padding: 1rem;
		align-items: start;
	}

	.home-main { min-width: 0; }

	.home-boxes {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		margin-top: 1rem;
	}

	.home-sidebar {
		border-left: 1px solid var(--border);
		padding-left: 1rem;
	}

	.recent-post {
		padding: 0.5rem 0;
		border-bottom: 1px solid var(--border);
	}

	.recent-post a {
		display: block;
		font-weight: bold;
		font-size: 0.85em;
		text-decoration: none;
		color: var(--link);
	}

	.recent-post a:hover {
		text-decoration: underline;
	}

	.recent-date {
		display: block;
		font-size: 0.75em;
		color: var(--text-dim);
		margin-top: 0.1rem;
	}

	@media (max-width: 700px) {
		.home-layout {
			grid-template-columns: 1fr;
		}
		.home-sidebar {
			border-left: none;
			border-top: 1px solid var(--border);
			padding-left: 0;
			padding-top: 1rem;
		}
		.home-boxes {
			grid-template-columns: 1fr;
		}
	}
</style>
