---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Subscribed — ${SITE_TITLE}`} description="Thanks for subscribing" />
	</head>
	<body>
		<Header />
		<div class="page-column">
			<div class="confirm-content">
				<h2>ALMOST THERE</h2>
				<p>Please check your e-mail to confirm the subscription. Once confirmed you'll receive updates whenever there's news from Kingfisher. Double check the junk folder if you don't receive anything!</p>
				<a class="more-link" href="/">Back to home &rarr;</a>
			</div>
		</div>
		<Footer />
	</body>
</html>

<style>
	.confirm-content {
		max-width: 560px;
		margin: 0 auto;
		padding: 2rem 1.5rem;
	}
	.confirm-content h1 {
		color: var(--red);
		font-size: 2rem;
		margin: 0 0 0.75rem;
	}
	.confirm-content p {
		line-height: 1.6;
		margin: 0 0 1rem;
		color: var(--text);
	}
</style>
